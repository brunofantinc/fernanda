---
import Navbar from '../components/navbar/Navbar.astro';
import Footer from '../components/footer/footer.astro';
import "../styles/global.css";
const title = Astro.props.title ? `${Astro.props.title} | BFC` : "BFC - Advocacia e Soluções Jurídicas";
---
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700;900&family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet" />
  </head>
  <body class="font-sans">
    <Navbar />
    <slot />
    <Footer />
  </body>
</html>
