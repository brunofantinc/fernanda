---
import heroBg from "../../assets/img/biblioteca-publica-fernanda-warm-v3.jpg";
---

<header
  id="home"
  class="relative h-screen bg-cover bg-center"
  style={`background-image: url(${heroBg.src})`}
>
  <div class="absolute inset-0 bg-black/70"></div>
  <main
    class="relative z-10 flex flex-col items-center justify-center h-full text-center px-4"
  >
    <h1 class="font-cinzel text-8xl md:text-[9rem] font-bold text-white mb-6 tracking-[0.3em] -mr-[0.3em]">FFC</h1>
    <p class="font-cormorant text-lg md:text-2xl text-white mb-8 max-w-2xl uppercase tracking-widest">
      advocacia e soluções jurídicas
    </p>
  </main>
</header>
